{
  "name": "subversa",
  "private": true,
  "license": "UNLICENSED",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "npm run check:frontend && npm run check:rust && npm run test:rust",
    "check:frontend": "npm run build && npm run test:unit",
    "check:rust": "cd src-tauri && cargo fmt --check && cargo clippy --all-targets -- -D warnings",
    "test:rust": "cd src-tauri && cargo test",
    "format:check": "cd src-tauri && cargo fmt --check",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "tauri": "tauri",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots=all",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lezer/common": "^1.5.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@uiw/codemirror-extensions-langs": "^4.25.10",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "diff": "^9.0.0",
    "framer-motion": "^12.40.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/diff": "^7.0.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
