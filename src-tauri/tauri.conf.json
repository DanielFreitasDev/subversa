{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Subversa",
  "version": "1.0.0",
  "identifier": "com.subversa.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Subversa",
        "width": 1320,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 640,
        "center": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Cliente SVN desktop moderno",
    "longDescription": "Subversa é um cliente Subversion de desktop com design moderno, no estilo do TortoiseSVN: status, commit, branches, merge (sync/reintegrate), histórico, diff e resolução de conflitos.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
